# YAMIL Browser Chat Service Configuration
# Copy to .env and fill in your values

# ── LLM Provider (Default: Ollama local) ──────────────────────────
# Ollama runs on your host machine, accessed via host.docker.internal
OLLAMA_URL=http://host.docker.internal:11434
LLM_PREFER_LOCAL=true
LLM_FALLBACK_CHAIN=ollama,gemini,openai,anthropic
DEFAULT_LLM_PROVIDER=auto

# ── Cloud Provider API Keys (Optional) ────────────────────────────
# Add keys for any cloud providers you want to use as fallback or primary.
# Leave empty to use Ollama only (zero cost, local, private).

# OpenAI (gpt-4o, gpt-4o-mini)
# OPENAI_API_KEY=sk-...

# Anthropic Claude (claude-3.5-sonnet, claude-3-opus, claude-3.5-haiku)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash)
# GOOGLE_API_KEY=AIza...

# xAI Grok (grok-2, grok-2-mini) — uses OpenAI-compatible API
# XAI_API_KEY=xai-...
# XAI_BASE_URL=https://api.x.ai/v1

# ── Service Config ────────────────────────────────────────────────
PORT=8020
LOG_LEVEL=INFO
UVICORN_WORKERS=2
SKIP_AUTH=true
USE_SECRETS_MANAGER=false
